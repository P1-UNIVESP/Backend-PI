generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id               String             @id @default(uuid())
  name             String
  cpf              String             @unique
  phone            String?
  plots            Plot[]             @relation("CurrentPlotOwner")
  ownershipHistory PlotOwnerHistory[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Plot {
  id       String     @id @default(uuid())
  code     String     @unique
  type     PlotType
  status   StatusPlot @default(DISPONIVEL)
  capacity Int

  ownerId String?
  owner   Owner?  @relation("CurrentPlotOwner", fields: [ownerId], references: [id])

  burials          Burial[]
  ownershipHistory PlotOwnerHistory[]
}

model PlotOwnerHistory {
  id        String    @id @default(uuid())
  plotId    String
  plot      Plot      @relation(fields: [plotId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([plotId])
  @@index([ownerId])
  @@index([plotId, endedAt])
}

model Deceased {
  id               String   @id @default(uuid())
  name             String
  birthDate        DateTime
  deathDate        DateTime
  deathCertificate String   @unique

  burial Burial?
}

model Burial {
  id         String   @id @default(uuid())
  burialDate DateTime

  plotId String
  plot   Plot   @relation(fields: [plotId], references: [id])

  deceasedId String   @unique
  deceased   Deceased @relation(fields: [deceasedId], references: [id])
}

enum PlotType {
  TERRA
  GAVETA
  MAUSOLEU
}

enum StatusPlot {
  DISPONIVEL
  OCUPADO
  MANUTENCAO
}

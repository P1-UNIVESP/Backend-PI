generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id        Int      @id @default(autoincrement())
  name      String
  cpf       String   @unique
  telefone  String?
  plots     Plot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plot {
  id       Int        @id @default(autoincrement())
  code     String     @unique
  type     PlotType
  status   StatusPlot @default(DISPONIVEL)
  capacity Int

  ownerId Int?
  owner   Owner? @relation(fields: [ownerId], references: [id])

  burials Burial[]
}

model Deceased {
  id              Int      @id @default(autoincrement())
  name            String
  dataNascimento  DateTime
  dataFalecimento DateTime
  certidaoObito   String   @unique

  burial Burial?
}

model Burial {
  id         Int      @id @default(autoincrement())
  burialDate DateTime

  plotId Int
  plot   Plot @relation(fields: [plotId], references: [id])

  deceasedId Int      @unique
  deceased   Deceased @relation(fields: [deceasedId], references: [id])
}

enum PlotType {
  TERRA
  GAVETA
  MAUSOLEU
}

enum StatusPlot {
  DISPONIVEL
  OCUPADO
  MANUTENCAO
}
